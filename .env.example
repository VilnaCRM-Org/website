# Example environment file. Copy to `.env` for local development and fill in the
# values. `NEXT_PUBLIC_*` variables are validated at build time by
# `src/config/env.ts` (Zod) and inlined into the static export (`output:
# 'export'`); a missing or malformed required value fails `next build` fast.
#
# The project is open source and ships no secrets, so `.env` and `.env.production`
# are committed. Only `.env*.local` is gitignored.

# --- Infrastructure hosts / ports (dev + test stacks) ---
GRAPHQL_API_PATH=graphql
GRAPHQL_LOG_LEVEL=info
HEALTH_CHECK_PATH=health
MOCKOON_HOST=mockoon
NEXT_PUBLIC_PROD_HOST=prod
WEBSITE_DOMAIN=localhost

DEV_PORT=3000
GRAPHQL_PORT=4000
MOCKOON_PORT=8080
NEXT_PUBLIC_PROD_PORT=3001
PLAYWRIGHT_TEST_PORT=9324
STORYBOOK_PORT=6006
UI_HOST=0.0.0.0

# --- Endpoints (consumed by the browser bundle via src/config/env.ts) ---
# GraphQL endpoint the Apollo client talks to. Required, must be a URL.
NEXT_PUBLIC_GRAPHQL_API_URL=http://${WEBSITE_DOMAIN}:${GRAPHQL_PORT}/${GRAPHQL_API_PATH}
# REST API base used by Sentry trace propagation. Required, must be a URL.
NEXT_PUBLIC_API_URL=https://api.vilnacrm.com
# Optional extra Sentry trace-propagation origin. May be empty.
NEXT_PUBLIC_DEVELOPMENT_API_URL=http://${WEBSITE_DOMAIN}:${DEV_PORT}

# --- Test/infra endpoints (not part of the browser bundle) ---
NEXT_PUBLIC_MOCKOON_CONTAINER_API_URL=http://${MOCKOON_HOST}:${MOCKOON_PORT}
NEXT_PUBLIC_MOCKOON_LOCAL_API_URL=http://${WEBSITE_DOMAIN}:${MOCKOON_PORT}
NEXT_PUBLIC_PROD_HOST_API_URL=http://${WEBSITE_DOMAIN}:${NEXT_PUBLIC_PROD_PORT}
NEXT_PUBLIC_API_BASE_URL=http://${MOCKOON_HOST}:${MOCKOON_PORT}
NEXT_PUBLIC_CONTINUOUS_DEPLOYMENT_HEADER_NAME=no-aws-header-name
NEXT_PUBLIC_CONTINUOUS_DEPLOYMENT_HEADER_VALUE=no-aws-header-value

# --- Locale (gates <html lang> + i18next). Required, non-empty. ---
NEXT_PUBLIC_MAIN_LANGUAGE=uk
NEXT_PUBLIC_FALLBACK_LANGUAGE=en

# --- Contact + policy links (browser bundle via src/config/env.ts) ---
# Required, must be a valid email.
NEXT_PUBLIC_VILNACRM_GMAIL=info@vilnacrm.com
# Required, must be URLs.
NEXT_PUBLIC_VILNACRM_PRIVACY_POLICY_URL=https://github.com/VilnaCRM-Org/
NEXT_PUBLIC_VILNACRM_USE_POLICY_URL=https://github.com/VilnaCRM-Org/

# --- Observability / analytics. Optional: empty disables the feature. ---
# Sentry DSN (public ingestion key). Empty = Sentry disabled.
NEXT_PUBLIC_SENTRY_DSN=
# Google Analytics measurement id (G-XXXXXXXXXX). Empty = GA not rendered.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Schema / spec versions and misc build inputs ---
GRAPHQL_SCHEMA_VERSION=v2.4.1
GRAPHQL_SCHEMA_URL=https://raw.githubusercontent.com/VilnaCRM-Org/user-service/${GRAPHQL_SCHEMA_VERSION}/.github/graphql-spec/spec

CHROMIUM_PATH=/usr/bin/chromium
GRACEFUL_SHUTDOWN_TIMEOUT=20000

USER_SERVICE_SPEC_VERSION=v2.6.0
NEXT_PUBLIC_USER_SERVICE_OPENAI_SPEC_URL=https://raw.githubusercontent.com/VilnaCRM-Org/user-service/${USER_SERVICE_SPEC_VERSION}/.github/openapi-spec/spec.yaml

MEMLAB_DEBUG=true
MEMLAB_SKIP_WARMUP=true
