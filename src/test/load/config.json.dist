{
  "protocol": "http",
  "host": "prod",
  "port": "3001",
  "params": {
    "headers": {
      "Continuous-Deployment-Header-Name": "continuous-deployment-header-value"
    }
  },
  "delayBetweenScenarios": 30,
  "endpoints": {
    "homepage": {
      "setupTimeoutInMinutes": 10,
      "smoke": {
        "threshold": 2000,
        "rps": 5,
        "vus": 5,
        "duration": 10
      },
      "average": {
        "threshold": 1500,
        "rps": 15,
        "vus": 15,
        "duration": {
          "rise": 5,
          "plateau": 30,
          "fall": 5
        }
      },
      "stress": {
        "threshold": 3000,
        "rps": 75,
        "vus": 75,
        "duration": {
          "rise": 5,
          "plateau": 30,
          "fall": 5
        }
      },
      "spike": {
        "threshold": 5000,
        "rps": 150,
        "vus": 150,
        "duration": {
          "rise": 30,
          "fall": 10
        }
      }
    },
    "swagger": {
      "setupTimeoutInMinutes": 15,
      "smoke": {
        "threshold": 3000,
        "rps": 3,
        "vus": 3,
        "duration": 15
      },
      "average": {
        "threshold": 2500,
        "rps": 10,
        "vus": 10,
        "duration": {
          "rise": 5,
          "plateau": 45,
          "fall": 5
        }
      },
      "stress": {
        "threshold": 4000,
        "rps": 50,
        "vus": 50,
        "duration": {
          "rise": 5,
          "plateau": 45,
          "fall": 5
        }
      },
      "spike": {
        "threshold": 8000,
        "rps": 100,
        "vus": 100,
        "duration": {
          "rise": 30,
          "fall": 15
        }
      }
    }
  }
}
