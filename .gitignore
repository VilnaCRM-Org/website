# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
/.pnpm-store/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# generated i18n bundle (rebuilt by the next.config webpack hook and the Jest
# globalSetup; see scripts/localizationGenerator.js)
pages/i18n/localization.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
./tsconfig.tsbuildinfo

/.idea
.vsco

#lighthouse
.lighthouseci/
/lhci-reports-desktop
/lhci-reports-mobile

.vscode

storybook-static/
storybook-static-ci/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# stryker temp files
.stryker-tmp
/reports/

# k6 config
/src/test/load/config.json
/src/test/load/results

# memlab
/src/test/memory-leak/results

app.log
*.log

/public/swagger-schema.*

# Dockerfile build-performance gate (scripts/ci/docker_perf.sh) artifacts
/.docker-perf/

# rust-code-analysis host binary (scripts/ci/ensure-rca.sh) — provisioned on
# demand, pinned + SHA256-verified, never committed (it is not an npm dep).
/bin/

# Local directories generated by the BMAD agent tool (bmalph) — local-only, not committed.
# Only the produced artifacts under specs/ are committed. The repo-local AI-agent docs
# (CLAUDE.md, cursor-project-guide.md, and .claude/skills/**) ARE committed; only bmalph's
# generated slash-command stubs under .claude/commands/ stay local.
/_bmad/
/_bmad-output/
/bmalph/
/.ralph/
/.claude/commands/
