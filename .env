GRAPHQL_API_PATH=graphql
GRAPHQL_LOG_LEVEL=info
HEALTH_CHECK_PATH=health
MOCKOON_HOST=mockoon
NEXT_PUBLIC_PROD_HOST=prod
WEBSITE_DOMAIN=localhost

DEV_PORT=3000
GRAPHQL_PORT=4000
MOCKOON_PORT=8080
NEXT_PUBLIC_PROD_PORT=3001
PLAYWRIGHT_TEST_PORT=9324
STORYBOOK_PORT=6006
UI_HOST=0.0.0.0

NEXT_PUBLIC_DEVELOPMENT_API_URL=http://${WEBSITE_DOMAIN}:${DEV_PORT}
NEXT_PUBLIC_GRAPHQL_API_URL=http://${WEBSITE_DOMAIN}:${GRAPHQL_PORT}/${GRAPHQL_API_PATH}
NEXT_PUBLIC_MOCKOON_CONTAINER_API_URL=http://${MOCKOON_HOST}:${MOCKOON_PORT}
NEXT_PUBLIC_MOCKOON_LOCAL_API_URL=http://${WEBSITE_DOMAIN}:${MOCKOON_PORT}
NEXT_PUBLIC_PROD_HOST_API_URL=http://${WEBSITE_DOMAIN}:${NEXT_PUBLIC_PROD_PORT}

NEXT_PUBLIC_FALLBACK_LANGUAGE=en
NEXT_PUBLIC_MAIN_LANGUAGE=uk

NEXT_PUBLIC_API_BASE_URL=http://${MOCKOON_HOST}:${MOCKOON_PORT}
NEXT_PUBLIC_CONTINUOUS_DEPLOYMENT_HEADER_NAME=no-aws-header-name
NEXT_PUBLIC_CONTINUOUS_DEPLOYMENT_HEADER_VALUE=no-aws-header-value
NEXT_PUBLIC_VILNACRM_GMAIL=info@vilnacrm.com
NEXT_PUBLIC_VILNACRM_PRIVACY_POLICY_URL=https://github.com/VilnaCRM-Org/
NEXT_PUBLIC_API_URL=https://yourserver.io/api/

# Single upstream pin. Every user-service contract — the GraphQL schema behind
# the Apollo mock, the OpenAPI spec behind the swagger page, and the Mockoon
# fixture used by e2e — is fetched from this one tag. Bump it with
# `make update-contracts`, which refreshes the committed artifacts under
# contracts/; `make lint-contracts` fails if they drift from the pin.
USER_SERVICE_VERSION=v2.6.0
GRAPHQL_SCHEMA_URL=https://raw.githubusercontent.com/VilnaCRM-Org/user-service/${USER_SERVICE_VERSION}/.github/graphql-spec/spec

CHROMIUM_PATH=/usr/bin/chromium
GRACEFUL_SHUTDOWN_TIMEOUT=20000

NEXT_PUBLIC_USER_SERVICE_OPENAI_SPEC_URL=https://raw.githubusercontent.com/VilnaCRM-Org/user-service/${USER_SERVICE_VERSION}/.github/openapi-spec/spec.yaml

MEMLAB_DEBUG=true
MEMLAB_SKIP_WARMUP=true
